generator client {
  provider = "prisma-client-js"
}

generator client_custom {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String             @id @default(uuid()) @db.Uuid
  name        String             @unique
  status      OrganizationStatus
  created_at  DateTime           @default(now())
  updated_at  DateTime           @default(now()) @updatedAt
  email       String
  phone       String
  courses     Course[]
  groups      Group[]
  leads       Lead[]
  notes       Note[]
  payments    Payment[]
  students    Student[]
  users       User[]
  enrollments Enrollment[]
  attendances Attendance[]
  progresses  Progress[]
  exams       Exam[]
  tests       Test[]
  expenses    Expense[]

  @@index([status])
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  full_name       String
  email           String
  password        String
  role            UserRole
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  phone           String       @unique
  refresh_token   String?
  teachingGroups  Group[]      @relation("GroupTeacher")
  notes           Note[]
  expenses        Expense[]
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, email])
  @@index([organization_id, role])
}

model Course {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  title           String
  description     String?
  price           String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  status          CourseStatus
  organization    Organization @relation(fields: [organization_id], references: [id])
  groups          Group[]
  lessons         Lesson[]

  @@index([organization_id])
  @@index([organization_id, status])
}

model Group {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  course_id       String       @db.Uuid
  teacher_id      String       @db.Uuid
  name            String
  start_date      DateTime     @db.Date
  end_date        DateTime     @db.Date
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  enrollments     Enrollment[]
  course          Course       @relation(fields: [course_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
  teacher         User         @relation("GroupTeacher", fields: [teacher_id], references: [id])

  @@index([organization_id])
  @@index([course_id])
  @@index([teacher_id])
}

model Lesson {
  id         String       @id @default(uuid()) @db.Uuid
  course_id  String       @db.Uuid
  title      String
  desc       String?
  start_date DateTime     @db.Date
  end_date   DateTime     @db.Date
  attendance Attendance[]
  exams      Exam[]
  course     Course       @relation(fields: [course_id], references: [id])
  progress   Progress[]
}

model Student {
  id              String        @id @default(uuid()) @db.Uuid
  organization_id String        @db.Uuid
  name            String
  parent          String?
  phone           String
  address         String
  status          StudentStatus
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now()) @updatedAt
  enrollments     Enrollment[]
  payments        Payment[]
  organization    Organization  @relation(fields: [organization_id], references: [id])

  // Prevent duplicate student phone numbers inside the same organization.
  @@unique([organization_id, phone])
  @@index([organization_id, status])
}

model Enrollment {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  student_id      String       @db.Uuid
  group_id        String       @db.Uuid
  enrolled_at     DateTime     @default(now())
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  attendance      Attendance[]
  group           Group        @relation(fields: [group_id], references: [id])
  student         Student      @relation(fields: [student_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
  progress        Progress[]

  // Prevent duplicate enrollments of the same student in the same group.
  @@unique([student_id, group_id])
  @@index([organization_id])
  @@index([student_id])
  @@index([group_id])
}

model Attendance {
  id              String           @id @default(uuid()) @db.Uuid
  organization_id String           @db.Uuid
  enrollment_id   String           @db.Uuid
  lesson_id       String           @db.Uuid
  status          AttendanceStatus
  marked_at       DateTime         @default(now())
  created_at      DateTime         @default(now())
  updated_at      DateTime         @default(now()) @updatedAt
  enrollment      Enrollment       @relation(fields: [enrollment_id], references: [id])
  lesson          Lesson           @relation(fields: [lesson_id], references: [id])
  organization    Organization     @relation(fields: [organization_id], references: [id])

  // Prevent duplicate attendance rows for the same lesson/enrollment.
  @@unique([enrollment_id, lesson_id])
  @@index([organization_id])
  @@index([lesson_id])
}

model Progress {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  enrollment_id   String       @db.Uuid
  lesson_id       String       @db.Uuid
  completed       Boolean
  title           String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  enrollment      Enrollment   @relation(fields: [enrollment_id], references: [id])
  lesson          Lesson       @relation(fields: [lesson_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([enrollment_id])
  @@index([lesson_id])
}

model Exam {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  lesson_id       String       @db.Uuid
  title           String
  desc            String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  lesson          Lesson       @relation(fields: [lesson_id], references: [id])
  tests           Test[]
  organization    Organization @relation(fields: [organization_id], references: [id])
}

model Test {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  exam_id         String       @map("exams_id") @db.Uuid
  question        String
  scores          Int
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  exam            Exam         @relation(fields: [exam_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
}

model Lead {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  admin           String
  full_name       String
  phone           String
  source          String
  status          LeadStatus
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  organization    Organization @relation(fields: [organization_id], references: [id])
  notes           Note[]

  // Prevent duplicate leads by phone inside the same organization.
  @@unique([organization_id, phone])
  @@index([organization_id, status])
}

model Note {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  lead_id         String       @db.Uuid
  user_id         String       @db.Uuid
  content         String
  created_at      DateTime     @default(now())
  lead            Lead         @relation(fields: [lead_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
  user            User         @relation(fields: [user_id], references: [id])
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  organization_id String        @db.Uuid
  student_id      String        @db.Uuid
  amount          Decimal
  method          PaymentMethod
  status          PaymentStatus @default(COMPLETED)
  description     String?
  paid_at         DateTime      @default(now())
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now()) @updatedAt
  organization    Organization  @relation(fields: [organization_id], references: [id])
  student         Student       @relation(fields: [student_id], references: [id])

  @@index([organization_id])
  @@index([organization_id, status])
  @@index([student_id])
}

model Expense {
  id              String          @id @default(uuid()) @db.Uuid
  organization_id String          @db.Uuid
  category        ExpenseCategory
  amount          Decimal
  description     String
  paid_at         DateTime        @default(now())
  created_by      String          @db.Uuid
  created_at      DateTime        @default(now())
  updated_at      DateTime        @default(now()) @updatedAt
  organization    Organization    @relation(fields: [organization_id], references: [id])
  creator         User            @relation(fields: [created_by], references: [id])

  @@index([organization_id])
  @@index([organization_id, category])
}

model Archive {
  id         String   @id @default(uuid()) @db.Uuid
  status     UserRole
  change     Json?
  created_at DateTime @default(now())
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  MANAGER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ExpenseCategory {
  SALARY
  RENT
  UTILITIES
  SUPPLIES
  MARKETING
  OTHER
}
