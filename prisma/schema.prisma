generator client {
  provider = "prisma-client-js"
}

generator client_custom {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String             @unique
  status             OrganizationStatus
  created_at         DateTime           @default(now())
  updated_at         DateTime           @default(now()) @updatedAt
  email              String
  phone              String
  // Notifications (per-organization)
  telegram_enabled   Boolean            @default(false)
  telegram_bot_token String?
  telegram_chat_id   String?

  whatsapp_enabled         Boolean           @default(false)
  whatsapp_cloud_token     String?
  whatsapp_phone_number_id String?
  whatsapp_api_version     String?           @default("v18.0")
  whatsapp_cloud_base_url  String?           @default("https://graph.facebook.com")
  whatsapp_target          String?
  courses                  Course[]
  groups                   Group[]
  leads                    Lead[]
  notes                    Note[]
  payments                 Payment[]
  notificationJobs         NotificationJob[]
  students                 Student[]
  users                    User[]
  enrollments              Enrollment[]
  attendances              Attendance[]
  progresses               Progress[]
  exams                    Exam[]
  tests                    Test[]
  expenses                 Expense[]
  invoices                 Invoice[]
  groupSchedules           GroupSchedule[]

  @@index([status])
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  full_name       String
  email           String
  password        String
  role            UserRole
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  phone           String       @unique
  refresh_token   String?
  teachingGroups  Group[]      @relation("GroupTeacher")
  cashierPayments Payment[]    @relation("PaymentCashier")
  notes           Note[]
  expenses        Expense[]
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, email])
  @@index([organization_id, role])
}

model Course {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  title           String
  description     String?
  price           String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  status          CourseStatus
  organization    Organization @relation(fields: [organization_id], references: [id])
  groups          Group[]
  lessons         Lesson[]

  @@index([organization_id])
  @@index([organization_id, status])
}

model Group {
  id              String          @id @default(uuid()) @db.Uuid
  organization_id String          @db.Uuid
  course_id       String          @db.Uuid
  teacher_id      String          @db.Uuid
  name            String
  start_date      DateTime        @db.Date
  end_date        DateTime        @db.Date
  created_at      DateTime        @default(now())
  updated_at      DateTime        @default(now()) @updatedAt
  enrollments     Enrollment[]
  schedules       GroupSchedule[]
  course          Course          @relation(fields: [course_id], references: [id])
  organization    Organization    @relation(fields: [organization_id], references: [id])
  teacher         User            @relation("GroupTeacher", fields: [teacher_id], references: [id])

  @@index([organization_id])
  @@index([course_id])
  @@index([teacher_id])
}

model GroupSchedule {
  id               String   @id @default(uuid()) @db.Uuid
  organization_id  String   @db.Uuid
  group_id         String   @db.Uuid
  // ISO-8601 weekday: 1=Mon .. 7=Sun
  day_of_week      Int
  // Minutes since 00:00 (e.g. 9:30 -> 570)
  start_minute     Int
  duration_minutes Int      @default(120)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])
  group        Group        @relation(fields: [group_id], references: [id])

  @@unique([group_id, day_of_week, start_minute])
  @@index([organization_id, day_of_week])
  @@index([group_id])
}

model Lesson {
  id         String       @id @default(uuid()) @db.Uuid
  course_id  String       @db.Uuid
  title      String
  desc       String?
  start_date DateTime     @db.Date
  end_date   DateTime     @db.Date
  attendance Attendance[]
  exams      Exam[]
  course     Course       @relation(fields: [course_id], references: [id])
  progress   Progress[]
}

model Student {
  id              String        @id @default(uuid()) @db.Uuid
  organization_id String        @db.Uuid
  name            String
  parent          String?
  phone           String
  address         String
  status          StudentStatus
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now()) @updatedAt
  enrollments     Enrollment[]
  payments        Payment[]
  invoices        Invoice[]
  organization    Organization  @relation(fields: [organization_id], references: [id])

  // Prevent duplicate student phone numbers inside the same organization.
  @@unique([organization_id, phone])
  @@index([organization_id, status])
}

model Enrollment {
  id              String        @id @default(uuid()) @db.Uuid
  organization_id String        @db.Uuid
  student_id      String        @db.Uuid
  group_id        String        @db.Uuid
  monthly_fee     Decimal       @default(0)
  billing_active  Boolean       @default(true)
  enrolled_at     DateTime      @default(now())
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now()) @updatedAt
  attendance      Attendance[]
  group           Group         @relation(fields: [group_id], references: [id])
  student         Student       @relation(fields: [student_id], references: [id])
  organization    Organization  @relation(fields: [organization_id], references: [id])
  progress        Progress[]
  invoiceItems    InvoiceItem[]

  // Prevent duplicate enrollments of the same student in the same group.
  @@unique([student_id, group_id])
  @@index([organization_id])
  @@index([student_id])
  @@index([group_id])
}

model Attendance {
  id              String           @id @default(uuid()) @db.Uuid
  organization_id String           @db.Uuid
  enrollment_id   String           @db.Uuid
  lesson_id       String           @db.Uuid
  status          AttendanceStatus
  marked_at       DateTime         @default(now())
  created_at      DateTime         @default(now())
  updated_at      DateTime         @default(now()) @updatedAt
  enrollment      Enrollment       @relation(fields: [enrollment_id], references: [id])
  lesson          Lesson           @relation(fields: [lesson_id], references: [id])
  organization    Organization     @relation(fields: [organization_id], references: [id])

  // Prevent duplicate attendance rows for the same lesson/enrollment.
  @@unique([enrollment_id, lesson_id])
  @@index([organization_id])
  @@index([lesson_id])
}

model Progress {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  enrollment_id   String       @db.Uuid
  lesson_id       String       @db.Uuid
  completed       Boolean
  title           String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  enrollment      Enrollment   @relation(fields: [enrollment_id], references: [id])
  lesson          Lesson       @relation(fields: [lesson_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([enrollment_id])
  @@index([lesson_id])
}

model Exam {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  lesson_id       String       @db.Uuid
  title           String
  desc            String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  lesson          Lesson       @relation(fields: [lesson_id], references: [id])
  tests           Test[]
  organization    Organization @relation(fields: [organization_id], references: [id])
}

model Test {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  exam_id         String       @map("exams_id") @db.Uuid
  question        String
  scores          Int
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  exam            Exam         @relation(fields: [exam_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
}

model Lead {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  admin           String
  full_name       String
  phone           String
  source          String
  status          LeadStatus
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  organization    Organization @relation(fields: [organization_id], references: [id])
  notes           Note[]

  // Prevent duplicate leads by phone inside the same organization.
  @@unique([organization_id, phone])
  @@index([organization_id, status])
}

model Note {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  lead_id         String       @db.Uuid
  user_id         String       @db.Uuid
  content         String
  created_at      DateTime     @default(now())
  lead            Lead         @relation(fields: [lead_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
  user            User         @relation(fields: [user_id], references: [id])
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  organization_id String        @db.Uuid
  student_id      String        @db.Uuid
  invoice_id      String?       @db.Uuid
  amount          Decimal
  method          PaymentMethod
  status          PaymentStatus @default(COMPLETED)
  description     String?
  receipt_number  String?
  cashier_user_id String?       @db.Uuid
  paid_at         DateTime      @default(now())
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now()) @updatedAt
  organization    Organization  @relation(fields: [organization_id], references: [id])
  student         Student       @relation(fields: [student_id], references: [id])
  invoice         Invoice?      @relation(fields: [invoice_id], references: [id])
  cashier         User?         @relation("PaymentCashier", fields: [cashier_user_id], references: [id])

  @@unique([organization_id, receipt_number])
  @@index([organization_id])
  @@index([organization_id, status])
  @@index([student_id])
  @@index([invoice_id])
  @@index([cashier_user_id])
}

model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  organization_id String        @db.Uuid
  student_id      String        @db.Uuid
  // First day of the invoice month (e.g., 2026-02-01).
  month           DateTime      @db.Date
  due_date        DateTime      @db.Date
  status          InvoiceStatus @default(OPEN)
  amount_due      Decimal
  amount_paid     Decimal       @default(0)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now()) @updatedAt

  organization Organization  @relation(fields: [organization_id], references: [id])
  student      Student       @relation(fields: [student_id], references: [id])
  payments     Payment[]
  items        InvoiceItem[]

  @@unique([organization_id, student_id, month])
  @@index([organization_id])
  @@index([organization_id, status])
  @@index([student_id])
  @@index([month])
}

model InvoiceItem {
  id            String   @id @default(uuid()) @db.Uuid
  invoice_id    String   @db.Uuid
  enrollment_id String   @db.Uuid
  amount        Decimal
  description   String?
  created_at    DateTime @default(now())

  invoice    Invoice    @relation(fields: [invoice_id], references: [id])
  enrollment Enrollment @relation(fields: [enrollment_id], references: [id])

  @@unique([invoice_id, enrollment_id])
  @@index([invoice_id])
  @@index([enrollment_id])
}

model Expense {
  id              String          @id @default(uuid()) @db.Uuid
  organization_id String          @db.Uuid
  category        ExpenseCategory
  amount          Decimal
  description     String
  paid_at         DateTime        @default(now())
  created_by      String          @db.Uuid
  created_at      DateTime        @default(now())
  updated_at      DateTime        @default(now()) @updatedAt
  organization    Organization    @relation(fields: [organization_id], references: [id])
  creator         User            @relation(fields: [created_by], references: [id])

  @@index([organization_id])
  @@index([organization_id, category])
}

model Archive {
  id         String   @id @default(uuid()) @db.Uuid
  status     UserRole
  change     Json?
  created_at DateTime @default(now())
}

model NotificationJob {
  id              String                @id @default(uuid()) @db.Uuid
  organization_id String                @db.Uuid
  channel         NotificationChannel
  type            String
  payload         Json
  status          NotificationJobStatus @default(PENDING)
  attempts        Int                   @default(0)
  next_run_at     DateTime              @default(now())
  last_error      String?
  sent_at         DateTime?
  created_at      DateTime              @default(now())
  updated_at      DateTime              @default(now()) @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status, next_run_at])
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  MANAGER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum InvoiceStatus {
  OPEN
  PAID
  OVERDUE
  VOID
}

enum NotificationChannel {
  TELEGRAM
  WHATSAPP
  EMAIL
  SMS
}

enum NotificationJobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum ExpenseCategory {
  SALARY
  RENT
  UTILITIES
  SUPPLIES
  MARKETING
  OTHER
}
