# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/crm"

# JWT (required; no insecure defaults in code)
JWT_ACCESS_SECRET="replace_with_a_strong_secret_at_least_32_chars"
JWT_REFRESH_SECRET="replace_with_a_strong_secret_at_least_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS
# In production, ALLOWED_ORIGINS must be set and must not contain "*".
ALLOWED_ORIGINS="http://localhost:3000"

# Platform seed (optional)
SUPER_ADMIN_EMAIL="+10000000000"
SUPER_ADMIN_PASSWORD="StrongPassword123"

# Notifications (optional)
TELEGRAM_BOT_TOKEN="replace_with_bot_token"
TELEGRAM_CHAT_ID="replace_with_chat_id"
WHATSAPP_TARGET="replace_with_group_or_number"
WHATSAPP_CLOUD_TOKEN="replace_with_meta_cloud_api_token"
WHATSAPP_PHONE_NUMBER_ID="replace_with_phone_number_id"
WHATSAPP_API_VERSION="v18.0"
WHATSAPP_CLOUD_BASE_URL="https://graph.facebook.com"
WHATSAPP_DEFAULT_LANG="uz"
NOTIFICATION_WORKER_BATCH=20
NOTIFICATION_WORKER_POLL_MS=2000

# WhatsApp templates (names must match templates configured in Meta)
# lesson_reminder: {{1}} student name, {{2}} course title, {{3}} start time
# payment_reminder: adjust parameters in src/worker.ts to match your template
