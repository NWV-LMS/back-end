# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/crm"

# JWT (required; no insecure defaults in code)
JWT_ACCESS_SECRET="replace_with_a_strong_secret_at_least_32_chars"
JWT_REFRESH_SECRET="replace_with_a_strong_secret_at_least_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS
# In production, ALLOWED_ORIGINS must be set and must not contain "*".
ALLOWED_ORIGINS="http://localhost:3000"

# Platform seed (optional)
SUPER_ADMIN_EMAIL="+10000000000"
SUPER_ADMIN_PASSWORD="StrongPassword123"

